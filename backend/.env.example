# Скопируйте в backend/.env и при необходимости отредактируйте.
# Нужен для локального запуска без Docker. В Docker значения приходят из
# docker-compose (environment), которые имеют приоритет над этим файлом.

# Название приложения
APP_NAME=FastAPI Shop

# Режим отладки / авто-reload (в проде: False)
DEBUG=True

# Строка подключения к БД.
# Локально (без Docker) можно SQLite:
DATABASE_URL=sqlite:///./shop.db
# Боевой вариант (PostgreSQL):
#   DATABASE_URL=postgresql+psycopg://fashop:fashop@localhost:5432/fashop

# Разрешённые источники CORS (через запятую или JSON-массивом)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Каталоги статики
STATIC_DIR=static
IMAGES_DIR=static/images

# --- Админ / JWT ---
ADMIN_USERNAME=admin
# bcrypt-хеш пароля (дефолт в коде соответствует паролю "admin" — только для разработки!)
ADMIN_PASSWORD_HASH=
JWT_SECRET=change-me-in-production-with-a-long-random-secret
