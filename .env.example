# Корневой .env для docker-compose / deploy.sh.
# Скопируйте в .env и заполните значения (deploy.sh создаёт его автоматически).

# Домен для Nginx и SSL-сертификатов
DOMAIN=example.com

# Email для Let's Encrypt
EMAIL=admin@example.com

# Название приложения
APP_NAME=FastAPI Shop

# Режим отладки (в проде: False)
DEBUG=False

# URL API для сборки фронтенда
VITE_API_BASE_URL=https://example.com/api

# --- PostgreSQL ---
POSTGRES_USER=fashop
POSTGRES_PASSWORD=change-me
POSTGRES_DB=fashop

# --- Админ / JWT ---
ADMIN_USERNAME=admin
# bcrypt-хеш пароля админа. Сгенерировать:
#   docker compose run --rm backend uv run python -c "import bcrypt;print(bcrypt.hashpw(b'ВАШ_ПАРОЛЬ', bcrypt.gensalt()).decode())"
# ВАЖНО: при вставке сюда экранируйте каждый '$' как '$$' (docker compose),
# иначе значение будет испорчено. deploy.sh делает это автоматически.
ADMIN_PASSWORD_HASH=
# Длинный случайный секрет: openssl rand -hex 32
JWT_SECRET=
